{
  "name": "mwbot-ts",
  "version": "1.3.2",
  "description": "A flexible JavaScript/TypeScript framework for building MediaWiki bots in Node.js.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "mwbot": "ts-node src/test/test_mwbot.ts",
    "mwbot-log": "node logger.mjs src/test/test_mwbot.ts _mwbot",
    "general": "ts-node src/test/test_general.ts",
    "Title": "ts-node src/test/test_Title.ts",
    "Wikitext": "ts-node src/test/test_Wikitext.ts",
    "Wikitext-log": "node logger.mjs src/test/test_Wikitext.ts _Wikitext",
    "readme": "ts-node src/test/test_readme.ts",
    "readme-log": "node logger.mjs src/test/test_readme.ts _readme",
    "readme-links": "npx markdown-link-check README.md",
    "test-build": "ts-node src/test/test_build.ts",
    "version": "node scripts/generate-version.mjs",
    "build": "npm run version && node scripts/empty-dir.mjs dist/build && tsc -p . && node scripts/generate-index.mjs",
    "docs": "node scripts/empty-dir.mjs docs && npx typedoc --options typedoc.json",
    "update": "update-version.sh",
    "test:setup": "cd tests/docker && bash setup.sh",
    "test:localwiki": "mocha tests/integration/localwiki/test.js",
    "test:testwiki": "node tests/integration/testwiki/run.js"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dr4goniez/mwbot-ts.git"
  },
  "keywords": [
    "mediawiki",
    "wikipedia",
    "wikimedia",
    "wiki",
    "nodejs",
    "javascript",
    "typescript",
    "api",
    "api-client",
    "wikitext"
  ],
  "author": "Dr4goniez",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/Dr4goniez/mwbot-ts/issues"
  },
  "homepage": "https://github.com/Dr4goniez/mwbot-ts#readme",
  "dependencies": {
    "axios": "^1.17.0",
    "axios-cookiejar-support": "^5.0.5",
    "form-data": "^4.0.5",
    "ip-wiki": "^2.0.0",
    "oauth-1.0a": "^2.2.6",
    "tough-cookie": "^5.1.2",
    "ts-essentials": "^10.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.2",
    "@types/tough-cookie": "^4.0.5",
    "chai": "^6.2.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "markdown-link-check": "^3.14.2",
    "mocha": "^11.7.6",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1"
  }
}
