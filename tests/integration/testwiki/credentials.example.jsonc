	/**
	 * Copy this file to credentials.json and fill in the required values.
	 *
	 * - Local runs read credentials.json directly.
	 * - In GitHub Actions CI, credentials.json is generated automatically
	 *   by run.js from repository secrets.
	 */
	"oAuth2AccessToken": "",
	"consumerToken": "",
	"consumerSecret": "",
	"accessToken": "",
	"accessSecret": "",
	"username": "",
	"password": "",
	"anonymous": true
}